# ==================== AI-Fusang .gitignore ====================
# 备份文件（任何 .bak / .bak-* 结尾）
*.bak
*.bak-*
index.html.bak-*
scene-switch.js.bak-*

# 截图（开发/测试期间生成）
screenshot-*.png
preview-*.png
center-*.png
verify-*.png

# 临时测试文件
test-*.html
probe-preview.html

# Release 临时 payload
release-payload.json

# 设计稿
design-mockup.html

# Python
__pycache__/
*.pyc
*.pyo

# 系统
.DS_Store
Thumbs.db
desktop.ini

# 编辑器
.vscode/
.idea/
*.swp
*.swo

# Node
node_modules/
npm-debug.log*
